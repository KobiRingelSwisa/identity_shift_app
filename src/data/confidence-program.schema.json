{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ConfidenceProgram",
  "type": "object",
  "required": ["track", "days"],
  "properties": {
    "track": {
      "type": "object",
      "required": ["id", "title", "duration_days", "estimated_session_minutes"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "duration_days": { "type": "integer", "minimum": 1 },
        "estimated_session_minutes": { "type": "number" }
      }
    },
    "days": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["day", "theme", "steps"],
        "properties": {
          "day": { "type": "integer", "minimum": 1 },
          "theme": { "type": "string" },
          "steps": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["type"],
              "properties": { "type": { "type": "string" } },
              "additionalProperties": true
            }
          }
        }
      }
    }
  }
}
